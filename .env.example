# Artifex Configuration
# Copy to .env and customize

# REQUIRED in production — random string for JWT signing
JWT_SECRET=change-me-to-a-random-string

# Instance identity (shown to federated peers)
INSTANCE_NAME=My Artifex Gallery
PUBLIC_URL=https://gallery.example.com

# Federation — allow other instances to discover and sync your public images
FEDERATION_ENABLED=true

# CORS — comma-separated allowed origins (empty = allow all in development)
ALLOWED_ORIGINS=

# Storage quota per user in bytes (default 5GB)
DEFAULT_STORAGE_QUOTA=5368709120

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# Server port
PORT=3002
